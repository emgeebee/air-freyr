{
  "serve": {
    "hostname": "0.0.0.0",
    "port": 3797,
    "queueDir": "/data/queues"
  },
  "dirs": {
    "output": "/data/music",
    "check": [],
    "cache": {
      "path": "<cache>",
      "keep": true
    }
  },
  "opts": {
    "netCheck": true,
    "attemptAuth": false,
    "autoOpenBrowser": false
  },
  "downloader": {
    "sources": ["yt_music", "youtube"]
  },
  "services": {
    "spotify": {},
    "apple_music": {
      "storefront": "us"
    },
    "deezer": {
      "retries": 2
    }
  }
}
